# Telegram
BOT_TOKEN=your_bot_token_here
WEBHOOK_URL=https://yourdomain.com/webhook
WEBHOOK_SECRET=random_secret_string

# База данных
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/friday_db

# Приложение
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Длительность задачи по умолчанию (минуты), если пользователь не указал
DEFAULT_TASK_DURATION=30

# AI (заглушка для Фазы 2)
OPENAI_API_KEY=
CLAUDE_API_KEY=

# Mini App
MINI_APP_URL=https://yourdomain.com/app
